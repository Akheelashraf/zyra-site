# Inquiry system – copy to .env.local and fill in values.
# For Netlify: set these in Site settings → Environment variables.

# Resend (email)
RESEND_API_KEY=
INQUIRY_TO_EMAIL=connect@zyrabuilds.com
RESEND_FROM_EMAIL=Zyra Builds <onboarding@resend.dev>

# WhatsApp Cloud API (optional – inquiry still succeeds if only email is configured)
